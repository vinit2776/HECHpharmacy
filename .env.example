# Database — use Neon pooler URL (hostname contains "-pooler")
DATABASE_URL="postgresql://user:password@ep-noisy-block-xxxxxxxx-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth v5 — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"
NEXTAUTH_URL="https://hceh-pharmacy-demo.vercel.app"

# Timezone (India Standard Time — affects same-day cancel window)
TZ="Asia/Kolkata"

# Vercel Cron secret — generate with: openssl rand -base64 32
# Set the same value in Vercel dashboard → Settings → Environment Variables
CRON_SECRET="replace-with-output-of-openssl-rand-base64-32"
